# queuestorm-investigator — environment configuration
#
# All keys are optional; missing keys fall back to documented defaults in
# ``app/config.py``. Place real secrets in your local untracked ``.env`` or
# in your deployment platform's secret store. This file ships with
# placeholders only and is safe to commit.

# ---- Process / transport ---------------------------------------------------

# PORT=8000

# LOG_LEVEL=INFO

# MAX_BODY_BYTES=65536

# REQUEST_TIMEOUT_MS=30000

# ---- Optional feature flags ------------------------------------------------

# METRICS_ENABLED=false

# PROFILE_ENABLED=false

# OTEL_ENABLED=false

# ---- Optional LLM provider -------------------------------------------------

# LLM_ENABLED=false

# LLM_API_KEY=

# LLM_MODEL=

# LLM_TIMEOUT_MS=1500

# LLM_CACHE_SIZE=1024
